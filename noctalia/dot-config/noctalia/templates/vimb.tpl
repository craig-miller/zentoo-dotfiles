# Rendered by Noctalia [theme.templates.user.vimb] into
# ~/.config/vimb/noctalia-theme.  Sourced by /etc/vimb/config after the
# post_hook `pkill -USR2 -x vimb` re-runs vimb's config parser.
# Do NOT hand-edit — regenerated on every palette apply.

set status-css=background-color:{{colors.surface.default.hex}};color:{{colors.on_surface.default.hex}};font-weight:bold;font-size:12pt;font-family:monospace;
set input-css=background-color:{{colors.surface.default.hex}};color:{{colors.on_surface.default.hex}};font-size:12pt;font-family:monospace;
set input-error-css=background-color:{{colors.error.default.hex}};color:{{colors.on_error.default.hex}};font-weight:bold;font-size:12pt;font-family:monospace;
set status-ssl-css=background-color:{{colors.surface.default.hex}};color:{{colors.primary.default.hex}};font-weight:bold;font-size:12pt;font-family:monospace;
set status-ssl-invalid-css=background-color:{{colors.error.default.hex}};color:{{colors.on_error.default.hex}};font-weight:bold;font-size:12pt;font-family:monospace;

set insert-css=background-color:{{colors.primary.default.hex}};color:{{colors.on_primary.default.hex}};font-weight:bold;font-size:12pt;font-family:monospace;
set command-css=background-color:{{colors.surface_container.default.hex}};color:{{colors.on_surface.default.hex}};font-weight:bold;font-size:12pt;font-family:monospace;
set hint-mode-css=background-color:{{colors.tertiary.default.hex}};color:{{colors.on_tertiary.default.hex}};font-weight:bold;font-size:12pt;font-family:monospace;
set pass-css=background-color:{{colors.secondary.default.hex}};color:{{colors.on_secondary.default.hex}};font-weight:bold;font-size:12pt;font-family:monospace;
set passthrough-css=background-color:{{colors.tertiary_container.default.hex}};color:{{colors.on_tertiary_container.default.hex}};font-weight:bold;font-size:12pt;font-family:monospace;

set completion-css=background-color:{{colors.surface_container.default.hex}};color:{{colors.on_surface.default.hex}};font-size:12pt;font-family:monospace;
set completion-hover-css=background-color:{{colors.surface_container_high.default.hex}};
set completion-selected-css=background-color:{{colors.primary_container.default.hex}};color:{{colors.on_primary_container.default.hex}};

set hint-label-css=background-color:{{colors.tertiary_container.default.hex}};border:1px solid {{colors.outline.default.hex}};color:{{colors.on_tertiary_container.default.hex}};opacity:0.95;
set hint-link-css=background-color:{{colors.tertiary.default.hex}} !important;color:{{colors.on_tertiary.default.hex}} !important;
set hint-focus-css=background-color:{{colors.primary.default.hex}} !important;color:{{colors.on_primary.default.hex}} !important;
