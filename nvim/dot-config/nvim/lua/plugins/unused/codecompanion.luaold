return {
    "olimorris/codecompanion.nvim",
    -- version = "^18.0.0",
    dependencies = {
        "nvim-lua/plenary.nvim",
        "nvim-treesitter/nvim-treesitter",
        -- "ravitemer/mcphub.nvim",
        "j-hui/fidget.nvim",
        "LukeGoodman/snacks.nvim",

    },
    keys = {
        { "<leader>ta", "<cmd>CodeCompanionChat Toggle<cr>", desc = "AI Chat" },

    },
    opts = {
        display = {
            action_palette = {
                -- provider = "snacks", -- Swaps the default float for Snacks.picker
                opts = {
                    width = 0.5,
                    height = 0.4,
                },
            },
        },
        adapters = {
            opts = {
                show_defaults = false,
            },
            ollama = {
                name = "ollama",
                -- model = "hf.co/unsloth/Qwen3-Coder-30B-A3B-Instruct-GGUF:UD-Q4_K_XL",
                model = "Qwen3-Coder-30B-A3B-Instruct-MLX-8bit",
            },
            -- anthropic = {
            --     name = "anthropic",
            --     model = "claude-3-5-sonnet-latest",
            -- },
            openai = {
                name = "openai",
                model = "gpt-4-turbo",
            },
            -- gemini = {
            --     name = "gemini",
            --     model = "gemini-1.5-pro",
            -- },
        },
        strategies = {
            chat = {
                adapter = {
                    name = "opencode",
                    model = "claude-sonnet-4",
                },
            },
        },
        interactions = {
            -- Define multiple adapters for chat

            -- Four kinds:
            -- Chat - A chat buffer where you can converse with an LLM (:CodeCompanionChat)
            -- Inline - An inline assistant that can write code directly into a buffer (:CodeCompanion)
            -- Cmd - Create Neovim commands in the command-line (:CodeCompanionCmd)
            -- Background - Runs tasks in the background such as compacting chat messages or generating titles for chats
            chat = { adapter = "openai", },
            inline = { adapter = "ollama", },
            cmd = { adapter = "ollama", },
            background = { adapter = "ollama", },
        },

        -- NOTE: The log_level is in `opts.opts`
        -- opts = { log_level = "DEBUG", },
    },
}
